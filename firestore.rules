rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: email (lowercase)
    // Fields:
    //   - email: string (required)
    //   - pin: string (required)
    //   - nombre: string (required)
    //   - securityQuestion: string (required)
    //   - securityAnswer: string (required)
    //
    // Collection: patients
    // Document ID: patientId
    // Fields:
    //   - id: string (required)
    //   - nombre: string (required)
    //   - edad: string
    //   - sexo: string
    //   - observaciones: string
    //   - telefono: string
    //   - email: string
    //   - coordinatorEmail: string
    //   - status: string (pending, sent, viewed, completed, concluded, finalized)
    //   - answers: map
    //   - conversationSummary: string
    //   - finalConclusion: string
    //   - conclusionViews: number
    //   - accessPin: string
    //   - dateSent: number
    //   - dateAnswered: number
    //   - dateConclusionSent: number
    //   - dateConclusionViewed: number
    //   - audioConclusion: string
    //
    // Collection: questionnaires
    // Document ID: active
    // Fields:
    //   - questions: list
    //
    // Collection: config
    // Document ID: global_config
    // Fields:
    //   - welcomeText: string
    //   - welcomeAudio: map
    //   - ... (otros campos de GlobalConfig)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email.lower() == email.lower();
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.uid == "7D079IDPnkcvJxB8sNSEbLKS1EY2" || 
              ('email' in request.auth.token && (
                request.auth.token.email == "davidcaparrosgarcia@gmail.com" ||
                request.auth.token.email == "cuestionarioespejo@gmail.com"
              )));
    }

    function isCoordinatorOf(patientData) {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             request.auth.token.email.lower() == patientData.coordinatorEmail.lower();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{email} {
      allow read: if true;
      allow write: if isAuthenticated() && (request.auth.token.email.lower() == email.lower() || isAdmin());
    }

    match /patients/{patientId} {
      allow get: if true; 
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if (isAuthenticated() && (isCoordinatorOf(resource.data) || isAdmin())) || (request.resource.data.id == resource.data.id);
      allow delete: if isAuthenticated() && (isCoordinatorOf(resource.data) || isAdmin());
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questionnaires/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /audios/{audioId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /test/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
